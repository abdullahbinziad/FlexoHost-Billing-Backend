NODE_ENV=development
PORT=5001
API_VERSION=v1

MONGODB_URI=mongodb://localhost:27017/billing-software?replicaSet=rs0
MONGODB_URI_TEST=mongodb://localhost:27017/billing-software-test?replicaSet=rs0

JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRATION=60m
JWT_REFRESH_EXPIRATION=7d
JWT_COOKIE_EXPIRES_IN=7

FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
API_URL=http://localhost:5001/api/v1
WEBSITE_URL=
CONTROL_PANEL_PROTOCOL=https
CONTROL_PANEL_PORT=2083
COMPANY_NAME=FlexoHost
SUPPORT_EMAIL=

COOKIE_ONLY_AUTH=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads
ENABLE_CLAMAV_SCAN=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# SMTP — required for transactional email (invoice, password reset, etc.)
# Configured only via environment on the API server (not stored in MongoDB).
# Missing USER/PASS = emails are skipped (logs: "SMTP not configured").
#
# Production checklist:
# [ ] Set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, EMAIL_FROM on the API host (Docker secrets / env file).
# [ ] Match provider docs: 465 + SMTP_SECURE=true + implicit TLS, OR 587 + STARTTLS (often SMTP_REQUIRE_TLS=true).
# [ ] Firewall/VPS: allow outbound TCP to host:port (test: openssl s_client -connect host:465 or :587).
# [ ] If ETIMEDOUT on VPS: try SMTP_FORCE_IPV4=true (broken IPv6).
# [ ] DNS: SPF (and ideally DKIM/DMARC) for the domain you send as — improves deliverability, not configured in app.
#
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Sender must be allowed by your provider. Use a verified mailbox or domain.
EMAIL_FROM=noreply@example.com
# Optional. HTTPS URL to your logo (PNG/JPEG recommended for older clients). Default logo is set in config.
# EMAIL_LOGO_INLINE=false — disable fetching the logo and embedding it as an inline image (CID).
EMAIL_LOGO_URL=
EMAIL_LOGO_INLINE=
# Optional TLS tuning (defaults are safe for Gmail / most hosts):
# SMTP_SECURE=true          — implicit SSL (typical port 465). Default: true only if SMTP_PORT=465
# SMTP_REQUIRE_TLS=false    — disable mandatory STARTTLS on 587 (only if your relay breaks)
# SMTP_TLS_REJECT_UNAUTHORIZED=false — allow self-signed SMTP certs (avoid in production)
# SMTP_CONNECTION_TIMEOUT_MS=25000
# SMTP_FORCE_IPV4=true   — use IPv4 only (try on VPS/Docker if SMTP times out; broken IPv6 is common)

BCRYPT_SALT_ROUNDS=12
SETTINGS_ENCRYPTION_KEY=replace-with-32-byte-hex-or-base64-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


NAMELY_API_KEY=
NAMELY_BASE_URL=https://api.namely.com.bd/v1/partner-api

SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false

WHMCS_MYSQL_HOST=127.0.0.1
WHMCS_MYSQL_PORT=3306
WHMCS_MYSQL_USER=root
WHMCS_MYSQL_PASSWORD=
WHMCS_MYSQL_DATABASE=whmcs_migrate
