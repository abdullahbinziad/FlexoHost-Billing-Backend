# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_COOKIE_EXPIRES_IN=7

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# Security
BCRYPT_SALT_ROUNDS=12

# Dynadot API Configuration
DYNADOT_API_KEY=your_dynadot_api_key
DYNADOT_API_SECRET=your_dynadot_api_secret
DYNADOT_BASE_URL=https://api.dynadot.com/restful/v2

# Namely API Configuration
NAMELY_API_KEY=your_namely_api_key
NAMELY_BASE_URL=https://api.namely.com.bd/v1/partner-api

# SSL Commerz Payment Gateway
