{
    "info": {
        "_postman_id": "domain-tld-api-standalone",
        "name": "Domain & TLD API",
        "description": "Standalone collection for testing Domain search, registration, and TLD management (CRUD).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "TLD Management (Admin)",
            "item": [
                {
                    "name": "Get All TLDs",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/domains/tld",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "domains",
                                "tld"
                            ]
                        }
                    }
                },
                {
                    "name": "Create TLD",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {\n    const jsonData = pm.response.json();\n    pm.collectionVariables.set('tldId', jsonData.data._id || jsonData.data.id);\n}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"tld\": \".com\",\n  \"isSpotlight\": true,\n  \"serial\": 1,\n  \"pricing\": [\n    {\n      \"currency\": \"BDT\",\n      \"1\": { \"register\": 1200, \"renew\": 1200, \"transfer\": 1100, \"enable\": true }\n    },\n    {\n      \"currency\": \"USD\",\n      \"1\": { \"register\": 12.99, \"renew\": 12.99, \"transfer\": 11.99, \"enable\": true }\n    }\n  ],\n  \"status\": \"active\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/domains/tld",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "domains",
                                "tld"
                            ]
                        }
                    }
                },
                {
                    "name": "Update TLD",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"isSpotlight\": false,\n  \"status\": \"active\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/domains/tld/:id",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "domains",
                                "tld",
                                ":id"
                            ],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "{{tldId}}"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Domain Operations",
            "item": [
                {
                    "name": "Search Domain",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/domains/search?domain=test.com",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "domains",
                                "search"
                            ],
                            "query": [
                                {
                                    "key": "domain",
                                    "value": "test.com"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Register Domain",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"domain\": \"test.com\",\n  \"duration\": 1\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/domains/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "domains",
                                "register"
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5001/api/v1"
        },
        {
            "key": "accessToken",
            "value": ""
        },
        {
            "key": "tldId",
            "value": ""
        }
    ]
}