# ================================
# Core
# ================================
NODE_ENV=production
API_VERSION=v1
PORT=5001

# ================================
# Public URLs (update to your domain on VPS)
# ================================
NEXT_PUBLIC_FRONTEND_URL=https://portal.flexohost.com
NEXT_PUBLIC_BACKEND_URL=https://portalapi.flexohost.com
NEXT_PUBLIC_API_TIMEOUT=30000
FRONTEND_URL=https://portal.flexohost.com
CORS_ORIGIN=https://portal.flexohost.com
API_URL=https://portalapi.flexohost.com/api/v1
WEBSITE_URL=https://portal.flexohost.com

# ================================
# Mongo / replica set
# ================================
MONGODB_URI=mongodb://mongo:27017/billing-software?replicaSet=rs0
MONGODB_URI_TEST=mongodb://mongo:27017/billing-software-test?replicaSet=rs0
MONGO_PUBLIC_PORT=27017

# ================================
# Security (replace with strong values)
# ================================
JWT_SECRET=replace-with-very-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-very-long-random-secret
JWT_ACCESS_EXPIRATION=60m
JWT_REFRESH_EXPIRATION=7d
JWT_COOKIE_EXPIRES_IN=7
COOKIE_ONLY_AUTH=false
COOKIE_DOMAIN=.flexohost.com

# ================================
# Rate limit / uploads
# ================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads
ENABLE_CLAMAV_SCAN=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ================================
# SMTP
# ================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_FORCE_IPV4=true
EMAIL_LOGO_URL=

# ================================
# OAuth / payment / integrations
# ================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAMELY_API_KEY=
NAMELY_BASE_URL=https://api.namely.com.bd/v1/partner-api
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false
DYNADOT_API_KEY=
DYNADOT_API_SECRET=

# ================================
# Optional: host exposed ports
# ================================
FRONTEND_PUBLIC_PORT=3000
BACKEND_PUBLIC_PORT=5001
