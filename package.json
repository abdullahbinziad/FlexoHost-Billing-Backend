{
    "name": "billing-backend",
    "version": "1.0.0",
    "description": "Secure MERN Backend for Billing Software",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "seed": "ts-node src/seeders/index.ts",
        "seed:force": "ts-node src/seeders/index.ts --force",
        "seed:clear": "ts-node src/seeders/index.ts --clear",
        "seed:users": "ts-node src/seeders/user.seeder.ts",
        "seed:users:force": "ts-node src/seeders/user.seeder.ts --force"
    },
    "keywords": [
        "express",
        "mongodb",
        "jwt",
        "typescript",
        "mern"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@types/node-fetch": "^2.6.13",
        "@types/nodemailer": "^7.0.9",
        "@types/uuid": "^10.0.0",
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "form-data": "^4.0.5",
        "helmet": "^7.1.0",
        "http-status": "^1.7.3",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-fetch": "^2.7.0",
        "nodemailer": "^8.0.0",
        "uuid": "^13.0.0",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/form-data": "^2.2.1",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "eslint": "^8.56.0",
        "prettier": "^3.1.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}
